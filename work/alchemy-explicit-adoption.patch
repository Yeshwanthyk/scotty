+      Effect.gen(function* () {
+        let reads = 0;
+        let writes = 0;
+        const read = () =>
+          Effect.sync(() => {
+            reads += 1;
+            return ownedAttrs;
+          });
+
+        const interrupted = yield* ExplicitAdoptionTestResource("Existing", {
+          string: "hello",
+        }).pipe(
+          adopt(true),
+          stack.deploy,
+          hook({
+            read,
+            update: () =>
+              Effect.sync(() => {
+                writes += 1;
+              }).pipe(Effect.andThen(Effect.interrupt)),
+          }),
