diff --git a/packages/alchemy/src/AdoptPolicy.ts b/packages/alchemy/src/AdoptPolicy.ts
index fcd1411d..9e522a2b 100644
--- a/packages/alchemy/src/AdoptPolicy.ts
+++ b/packages/alchemy/src/AdoptPolicy.ts
@@ -23,9 +23,10 @@ import * as Effect from "effect/Effect";
  *
  * "Owned" means a provider has affirmatively determined the resource was
  * created by this stack/stage/logical-id (typically by inspecting tags or
- * naming conventions). Resources without ownership semantics simply always
- * return plain attrs — they are treated as owned by default, so silent
- * adoption is the norm and `--adopt` is unnecessary.
+ * naming conventions). By default, resources without ownership semantics
+ * return plain attrs and are silently adopted. Resource types with an
+ * explicit adoption policy instead treat plain attrs as foreign when local
+ * state is absent, so takeover requires `--adopt` (or `adopt(true)`).
  *
  * The policy can be overridden per-effect via {@link adopt} — most commonly
  * applied at the resource or stack scope.
