+        );
+
+        expect(Exit.isFailure(interrupted)).toBe(true);
+        expect(reads).toBe(1);
+        expect(writes).toBe(1);
+        expect(yield* getState("Existing")).toBeUndefined();
+        expect(yield* listState()).toEqual([]);
+
+        yield* ExplicitAdoptionTestResource("Existing", {
+          string: "hello",
+        }).pipe(adopt(true), stack.deploy, hook({ read }));
+
+        expect(reads).toBe(2);
+        expect(yield* getState("Existing")).toMatchObject({
+          status: "updated",
+          attr: { string: "hello" },
+        });
+      }),
+  );
+
+  test.provider(
+    "explicit adoption overrides delete-first replacement until ownership is established",
+    (stack) =>
+      Effect.gen(function* () {
+        let writes = 0;
+        let deletes = 0;
+        const failure = hook({
+          read: () => Effect.succeed(ownedAttrs),
+          testResourceDiff: () =>
+            Effect.succeed({ action: "replace", deleteFirst: true }),
+          update: () =>
+            Effect.sync(() => {
+              writes += 1;
+            }).pipe(Effect.andThen(Effect.fail(new ResourceFailure()))),
+          delete: () =>
+            Effect.sync(() => {
+              deletes += 1;
+            }),
+        });
+
+        yield* ExplicitAdoptionTestResource("Existing", {
+          string: "hello",
+        }).pipe(adopt(true), stack.deploy, failure);
+
+        expect(writes).toBe(1);
+        expect(deletes).toBe(0);
+        expect(yield* getState("Existing")).toBeUndefined();
+
+        yield* stack.destroy().pipe(failure);
+        expect(deletes).toBe(0);
+      }),
+  );
+
+  test.provider(
+    "implicit adoption preserves its existing failed-update checkpoint and replay behavior",
+    (stack) =>
+      Effect.gen(function* () {
+        let reads = 0;
+        const read = () =>
+          Effect.sync(() => {
+            reads += 1;
+            return ownedAttrs;
+          });
+
+        yield* TestResource("Existing", { string: "hello" }).pipe(
+          stack.deploy,
+          hook({
+            read,
+            update: () => Effect.fail(new ResourceFailure()),
+          }),
+        );
+
+        expect(reads).toBe(1);
+        expect(yield* getState("Existing")).toMatchObject({
+          status: "updating",
+        });
+
+        yield* TestResource("Existing", { string: "hello" }).pipe(
+          stack.deploy,
+          hook({ read }),
+        );
+
+        expect(reads).toBe(1);
+        expect(yield* getState("Existing")).toMatchObject({
+          status: "updated",
+        });
+      }),
+  );
 });
 
