   AliasedWidget,
@@ -2204,6 +2207,209 @@ describe("retain removal policy on replace", () => {
   );
 });
 
+describe("persist removal policy-only changes", () => {
+  const program = (retain: boolean) =>
+    Effect.gen(function* () {
+      const A = yield* BindingTarget("A", {
+        name: "a",
+        string: "a-value",
+      }).pipe(RemovalPolicy.retain(retain));
+      const B = yield* TestResource("B", { string: A.string });
+      return { A, B };
+    });
+
+  test.provider(
+    "persists both policy directions without provider mutation and preserves state",
+    (stack) =>
+      Effect.gen(function* () {
+        yield* program(true).pipe(stack.deploy);
+        const retained = yield* getState("A");
+        expect(retained?.removalPolicy).toBe("retain");
+
+        let reconciles = 0;
+        let deletes = 0;
+        const countProviderCalls = hook({
+          create: () =>
+            Effect.sync(() => {
+              reconciles += 1;
+            }),
+          update: () =>
+            Effect.sync(() => {
+              reconciles += 1;
+            }),
+          delete: () =>
+            Effect.sync(() => {
+              deletes += 1;
+            }),
+        });
+
+        const destroyPlan = yield* stack.plan(program(false));
+        expect(destroyPlan.resources.A?.action).toBe("update-policy");
+        expect(destroyPlan.resources.B?.action).toBe("noop");
+
+        yield* program(false).pipe(stack.deploy, countProviderCalls);
+        const destroyed = yield* getState("A");
+        expect(destroyed).toEqual({
+          ...retained,
+          removalPolicy: "destroy",
+        });
+        expect(reconciles).toBe(0);
+        expect(deletes).toBe(0);
+
+        const retainPlan = yield* stack.plan(program(true));
+        expect(retainPlan.resources.A?.action).toBe("update-policy");
+        expect(retainPlan.resources.B?.action).toBe("noop");
+
+        yield* program(true).pipe(stack.deploy, countProviderCalls);
+        expect(yield* getState("A")).toEqual(retained);
+        expect(reconciles).toBe(0);
+        expect(deletes).toBe(0);
+      }),
+  );
+
+  test.provider("commits policy before publishing terminal status", (stack) =>
+    Effect.gen(function* () {
+      yield* program(true).pipe(stack.deploy);
+
+      const observations: string[] = [];
+      const state = yield* yield* State;
+      const cli = Cli.of({
+        approvePlan: () => Effect.succeed(true),
+        displayPlan: () => Effect.void,
+        startApplySession: () =>
+          Effect.succeed({
+            done: () => Effect.void,
+            emit: (event) =>
+              event.kind === "status-change" &&
+              event.id === "A" &&
+              event.status === "updated"
+                ? state
+                    .get({ stack: stack.name, stage: "test", fqn: "A" })
+                    .pipe(
+                      Effect.catch((error) => Effect.die(error)),
+                      Effect.map((persisted) => {
+                        observations.push(
+                          isResourceState(persisted)
+                            ? (persisted.removalPolicy ?? "missing")
+                            : "missing",
+                        );
+                      }),
+                    )
+                : Effect.void,
+          }),
+      });
+
+      yield* program(false).pipe(
+        stack.deploy,
+        Effect.provide(Layer.succeed(Cli, cli)),
+      );
+
+      expect(observations.length).toBeGreaterThan(0);
+      expect(observations.every((policy) => policy === "destroy")).toBe(true);
+    }),
+  );
+
+  test.provider(
+    "replans after interruption before commit and converges after interruption following commit",
+    (stack) =>
+      Effect.gen(function* () {
+        yield* program(true).pipe(stack.deploy);
+
+        const state = yield* yield* State;
+        const originalSet = state.set;
+        let interruptNextSet = true;
+        yield* Effect.sync(() => {
+          state.set = (request) => {
+            if (interruptNextSet) {
+              interruptNextSet = false;
+              return Effect.interrupt;
+            }
+            return originalSet(request);
+          };
+        });
+
+        const beforeCommit = yield* program(false).pipe(
+          stack.deploy,
+          Effect.exit,
+          Effect.ensuring(
+            Effect.sync(() => {
+              state.set = originalSet;
+            }),
+          ),
+        );
+        expect(Exit.isFailure(beforeCommit)).toBe(true);
+        if (Exit.isFailure(beforeCommit)) {
+          expect(Cause.hasInterrupts(beforeCommit.cause)).toBe(true);
+        }
+        expect((yield* stack.plan(program(false))).resources.A?.action).toBe(
+          "update-policy",
+        );
+
+        const interruptingCli = Cli.of({
+          approvePlan: () => Effect.succeed(true),
+          displayPlan: () => Effect.void,
+          startApplySession: () =>
+            Effect.succeed({
+              done: () => Effect.void,
+              emit: (event) =>
+                event.kind === "status-change" &&
+                event.id === "A" &&
+                event.status === "updated"
+                  ? Effect.interrupt
+                  : Effect.void,
+            }),
+        });
+        const afterCommit = yield* program(false).pipe(
+          stack.deploy,
+          Effect.provide(Layer.succeed(Cli, interruptingCli)),
+          Effect.exit,
+        );
+        expect(Exit.isFailure(afterCommit)).toBe(true);
+        if (Exit.isFailure(afterCommit)) {
+          expect(Cause.hasInterrupts(afterCommit.cause)).toBe(true);
+        }
+        expect((yield* getState("A"))?.removalPolicy).toBe("destroy");
+        expect((yield* stack.plan(program(false))).resources.A?.action).toBe(
+          "noop",
+        );
+      }),
+  );
+
+  test.provider(
+    "migrates a legacy missing policy to retain and then noops",
+    (stack) =>
+      Effect.gen(function* () {
+        yield* program(false).pipe(stack.deploy);
+
+        const state = yield* yield* State;
+        const persisted = yield* state.get({
+          stack: stack.name,
+          stage: "test",
+          fqn: "A",
+        });
+        if (!isResourceState(persisted)) {
+          return expect.fail("expected resource state for A");
+        }
+        const { removalPolicy: _removed, ...legacy } = persisted;
+        yield* state.set({
+          stack: stack.name,
+          stage: "test",
+          fqn: "A",
+          value: legacy,
+        });
+
+        expect((yield* stack.plan(program(true))).resources.A?.action).toBe(
+          "update-policy",
+        );
+        yield* program(true).pipe(stack.deploy);
+        expect((yield* getState("A"))?.removalPolicy).toBe("retain");
+        expect((yield* stack.plan(program(true))).resources.A?.action).toBe(
+          "noop",
+        );
+      }),
+  );
+});
+
 describe("from deleting state", () => {
   test.provider(
     "create when props unchanged or have updatable changes",
