+describe("removal policy-only changes", () => {
+  const state = (removalPolicy?: "retain" | "destroy"): ResourceState => ({
+    instanceId,
+    providerVersion: 0,
+    logicalId: "A",
+    fqn: "A",
+    namespace: undefined,
+    resourceType: "Test.TestResource",
+    status: "created",
+    props: { string: "value" },
+    attr: {
+      string: "value",
+      stringArray: [],
+      stableString: "A",
+      stableArray: ["A"],
+      replaceString: undefined,
+      redacted: undefined,
+      redactedArray: undefined,
+    },
+    bindings: [],
+    downstream: [],
+    removalPolicy,
+  });
+
+  test(
+    "retain to destroy emits an approval-visible policy action only",
+    Effect.gen(function* () {
+      yield* seed({ A: state("retain") });
+
+      const plan = yield* Effect.gen(function* () {
+        yield* TestResource("A", { string: "value" });
+      }).pipe(makePlan);
+
+      expect(plan.resources.A?.action).toBe("update-policy");
+      expect(plan.deletions).toEqual({});
+      expect(Plan.printPlan(plan)).toContain("[p] A (Test.TestResource)");
+      expect(Plan.printPlan(plan)).toContain("± replace, = noop");
+    }),
+  );
+
+  test(
+    "destroy to retain emits an approval-visible policy action only",
+    Effect.gen(function* () {
+      yield* seed({ A: state("destroy") });
+
+      const plan = yield* Effect.gen(function* () {
+        yield* TestResource("A", { string: "value" }).pipe(
+          RemovalPolicy.retain(),
+        );
+      }).pipe(makePlan);
+
+      expect(plan.resources.A?.action).toBe("update-policy");
+      expect(plan.deletions).toEqual({});
+      expect(Plan.printPlan(plan)).toContain("[p] A (Test.TestResource)");
+    }),
+  );
+
+  test(
+    "legacy missing policy is equivalent to destroy",
+    Effect.gen(function* () {
+      yield* seed({ A: state() });
+
+      const plan = yield* Effect.gen(function* () {
+        yield* TestResource("A", { string: "value" });
+      }).pipe(makePlan);
+
+      expect(plan.resources.A?.action).toBe("noop");
+    }),
+  );
+});
