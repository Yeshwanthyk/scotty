{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".pi/**",
    ".wrangler/**",
    "dist/**",
    "**/node_modules/**",
    "vendor/**",
    "work/**",
    "worker/public/vendor/**"
  ],
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "no-debugger": "error"
  }
}
