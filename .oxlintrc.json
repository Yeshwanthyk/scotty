{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [{ "name": "scotty", "specifier": "./scripts/oxlint-plugin-scotty.js" }],
  "ignorePatterns": [
    ".pi/**",
    ".wrangler/**",
    "dist/**",
    "**/node_modules/**",
    "vendor/**",
    "work/**",
    "worker/public/vendor/**"
  ],
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "no-debugger": "error",
    "scotty/no-conditional-tests": "error",
    "scotty/no-double-cast": "error",
    "scotty/no-effect-escape-hatch": "error",
    "scotty/no-effect-run-sync-in-tests": "error",
    "scotty/no-inline-object-type-assertion": "error",
    "scotty/no-inline-schema-compile": "error",
    "scotty/no-manual-tag-check": "error",
    "scotty/no-match-orelse": "error",
    "scotty/no-promise-client-surface": "error",
    "scotty/no-raw-error-throw": "error",
    "scotty/no-redundant-error-factory": "error",
    "scotty/no-redundant-primitive-cast": "error",
    "scotty/no-schema-class": "error",
    "scotty/no-switch-statement": "error",
    "scotty/no-ts-nocheck": "error",
    "scotty/no-unsupported-effect-api": "error",
    "scotty/prefer-effect-predicate": "error",
    "scotty/prefer-schema-inferred-types": "error",
    "scotty/prefer-value-inferred-extension-types": "error"
  },
  "overrides": [
    {
      "files": [
        "alchemy.run.ts",
        "worker/src/contracts.ts",
        "spikes/infra/account-secrets-store-canary.run.ts",
        "spikes/infra/account-secrets-store-canary.ts",
        "spikes/infra/external-sandbox-container-binding.ts",
        "spikes/infra/local-secret-source.ts",
        "spikes/infra/monolith-greenfield.ts",
        "spikes/infra/sandbox-sdk-canary.ts",
        "spikes/infra/write-only-secret-cloudflare.ts",
        "spikes/infra/write-only-secret.ts"
      ],
      "rules": {
        "scotty/no-effect-runtime-escape": "error",
        "scotty/no-error-constructor": "error",
        "scotty/no-instanceof-error": "error",
        "scotty/no-json-parse": "error",
        "scotty/no-promise-reject": "error",
        "scotty/no-raw-error-throw": "off",
        "scotty/no-raw-fetch": "error",
        "scotty/no-raw-wall-clock": "error",
        "scotty/no-try-catch-or-throw": "error"
      }
    }
  ]
}
